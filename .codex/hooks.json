{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$HOME/.codex-mdfy/run_session_archiver_hook.sh\"",
            "statusMessage": "Initializing Markdown session archive"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$HOME/.codex-mdfy/run_session_archiver_hook.sh\"",
            "timeout": 30,
            "statusMessage": "Updating Markdown session archive"
          }
        ]
      }
    ]
  }
}
